# Deployment configuration
# Copy this to .env and fill in your values (never commit .env)

GIT_REPOSITORY=https://github.com/your-org/bln-academy.git

# Production server
PROD_HOSTNAME=yourdomain.com
PROD_PORT=22
PROD_USER=cpanel_username
PROD_DEPLOY_PATH=/home/cpanel_username/public_html

# Staging server
STAGING_HOSTNAME=yourdomain.com
STAGING_PORT=22
STAGING_USER=cpanel_username
STAGING_DEPLOY_PATH=/home/cpanel_username/staging

# SSH private key (add to GitHub Secrets as DEPLOY_SSH_KEY)
